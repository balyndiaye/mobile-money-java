        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam shadowing false\nskinparam packageStyle rectangle\nskinparam roundcorner 10\n\n&#39; Configuration des couleurs par défaut\nskinparam class {\n    BackgroundColor White\n    ArrowColor #263238\n    BorderColor #263238\n}\n\npackage \&quot;model\&quot; #E1F5FE {\n    class Client #B3E5FC {\n        - id : int\n        - nom : String\n        - prenom : String\n        - telephone : String\n        - adresse : String\n        + Client(nom, prenom, telephone, adresse)\n        + getId() : int\n        + getNom() : String\n        + getPrenom() : String\n        + getTelephone() : String\n        + getAdresse() : String\n    }\n\n    class Compte #B3E5FC {\n        - id : int\n        - numero : String\n        - solde : double\n        - client : Client\n        + Compte(numero, solde, client)\n        + getId() : int\n        + getNumero() : String\n        + getSolde() : double\n        + getClient() : Client\n    }\n\n    class Marchand #B3E5FC {\n        - id : int\n        - nom : String\n        - codeMarchand : String\n        - compte : Compte\n        + Marchand(nom, codeMarchand, compte)\n        + getId() : int\n        + getNom() : String\n        + getCodeMarchand() : String\n        + getCompte() : Compte\n    }\n\n    class Operation #B3E5FC {\n        - id : int\n        - type : String\n        - montant : double\n        - dateOp : Timestamp\n        - compteSource : String\n        - compteDest : String\n        + Operation(type, montant, source, dest)\n        + getType() : String\n        + getMontant() : double\n        + getDateOp() : Timestamp\n        + getCompteSource() : String\n        + getCompteDest() : String\n    }\n}\n\npackage \&quot;database\&quot; #FFF9C4 {\n    class DatabaseConnection #FFF176 {\n        - {static} URL : String\n        - {static} USER : String\n        - {static} PASSWORD : String\n        - {static} connection : Connection\n        + {static} getConnection() : Connection\n        + {static} closeConnection()\n    }\n}\n\npackage \&quot;dao\&quot; #F1F8E9 {\n    class ClientDAO #DCEDC8 {\n        + save(Client) : boolean\n        + findAll() : List&lt;Client&gt;\n        + findByTelephone(String) : Client\n    }\n\n    class CompteDAO #DCEDC8 {\n        + save(String, int) : boolean\n        + findByNumero(String) : Compte\n        + mettreAJourSolde(String, double) : boolean\n    }\n\n    class MarchandDAO #DCEDC8 {\n        + findAll() : List&lt;Marchand&gt;\n        + findByCode(String) : Marchand\n    }\n\n    class OperationDAO #DCEDC8 {\n        + enregistrerOperation(Operation) : boolean\n        + findByCompte(String) : List&lt;Operation&gt;\n        + getStatsGlobales() : Map&lt;String, Double&gt;\n    }\n}\n\npackage \&quot;services\&quot; #E8EAF6 {\n    class ClientService #C5CAE9 {\n        + ajouterClient(nom, prenom, tel, adr) : String\n        + listerClients() : List&lt;Client&gt;\n    }\n\n    class CompteService #C5CAE9 {\n        + creerCompte(telephone) : String\n        + genererNumeroUnique() : String\n    }\n\n    class OperationService #C5CAE9 {\n        + effectuerDepot(numero, montant) : String\n        + effectuerRetrait(numero, montant) : String\n        + effectuerTransfert(source, dest, montant) : String\n        + effectuerPaiementMarchand(source, codeM, montant) : String\n        + consulterHistorique(numero) : List&lt;Operation&gt;\n        + consulterStatsGlobales() : Map&lt;String, Double&gt;\n    }\n}\n\npackage \&quot;ui\&quot; #F3E5F5 {\n    class Menu #E1BEE7 {\n        - sc : Scanner\n        + afficherMenuPrincipal()\n        - ajouterClient()\n        - creerCompte()\n        - effectuerDepot()\n        - effectuerRetrait()\n        - effectuerTransfert()\n        - effectuerPaiementMarchand()\n        - afficherHistorique()\n        - afficherStatistiques()\n    }\n\n    class Main #E1BEE7 {\n        + {static} main(args : String[])\n    }\n}\n\n&#39; Relations de composition/aggrégation\nCompte \&quot;1\&quot; -- \&quot;1\&quot; Client : appartient à\nMarchand \&quot;1\&quot; -- \&quot;1\&quot; Compte : possède\nOperation \&quot;0..*\&quot; -- \&quot;1\&quot; Compte : concerne\n\n&#39; Relations d&#39;utilisation (Dépendances)\nMenu ..&gt; ClientService\nMenu ..&gt; CompteService\nMenu ..&gt; OperationService\nMain ..&gt; Menu\n\nClientService ..&gt; ClientDAO\nCompteService ..&gt; CompteDAO\nOperationService ..&gt; OperationDAO\nOperationService ..&gt; CompteDAO\n\nClientDAO ..&gt; DatabaseConnection\nCompteDAO ..&gt; DatabaseConnection\nMarchandDAO ..&gt; DatabaseConnection\nOperationDAO ..&gt; DatabaseConnection\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Bc8vpw22AevgomOSZv5w-2">
